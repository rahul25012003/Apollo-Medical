// Prisma Schema for ICMS (Integrated Customer Management System)
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum ScanType {
  CHECK_IN
  ZONE_ACCESS
  FOOD_DISTRIBUTION
}

enum ScanResult {
  SUCCESS
  DENIED
  ALREADY_CHECKED_IN
  ALREADY_SERVED
  ZONE_FULL
  NOT_FOUND
  INVALID
}

enum UserRole {
  SUPER_ADMIN          // Full access to all features and settings (platform-level)
  ADMIN                // Full access within own tenant (tenant administrator)
  EVENT_MANAGER        // Manage events, speakers, and sponsors
  REGISTRATION_MANAGER // Handle registrations and attendee management
  CERTIFICATE_MANAGER  // Generate and distribute certificates
  ATTENDEE             // Regular user/attendee
}

enum EventStatus {
  DRAFT
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EventType {
  CONFERENCE
  WORKSHOP
  SEMINAR
  WEBINAR
  CME
  SYMPOSIUM
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  WAITLIST
  ATTENDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
  FREE
}

enum SponsorTier {
  PLATINUM
  GOLD
  SILVER
  BRONZE
}

enum OTPPurpose {
  REGISTRATION
  LOGIN
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

enum CertificateStatus {
  PENDING
  ISSUED
  REVOKED
}

enum PaymentMode {
  NONE              // No payment required / free events only
  RAZORPAY          // Razorpay payment gateway
  QR_CODE           // Manual QR code payment with proof upload
}

// ============================================================================
// TENANT MODEL (Multi-tenancy)
// ============================================================================

model Tenant {
  id                String   @id @default(cuid())

  // Identification
  slug              String   @unique  // Used in URL: medconf.com/t/slug or slug.medconf.com
  name              String             // Display name: "ABC Medical College"
  domain            String?  @unique  // Custom domain: "abcmedical.com"

  // Branding
  logo              String?            // Logo URL
  favicon           String?            // Favicon URL
  secondaryLogo     String?            // Secondary logo displayed above login button
  tagline           String?            // "Excellence in Medical Education"

  // Theme Colors (CSS variables)
  primaryColor      String   @default("#0d9488")   // teal-600
  secondaryColor    String   @default("#0891b2")   // cyan-600
  accentColor       String   @default("#10b981")   // emerald-500

  // Contact Information
  email             String?
  phone             String?
  address           String?
  city              String?
  state             String?
  country           String?
  website           String?

  // Map & Business Hours
  mapUrl            String?            // Google Maps embed URL
  businessHours     Json?              // JSON: { monFri, sat, sunHoliday }

  // Social Links
  facebook          String?
  twitter           String?
  linkedin          String?
  instagram         String?
  youtube           String?

  // Section Visibility + Dashboard Module Visibility + Notification Config (JSON for flexibility)
  // Frontpage: hero, events, gallery, sponsors, about, contact
  // Modules: moduleSpeakers, moduleSponsors, moduleCertificates, moduleRegistrations
  // Notifications: notifyRegistrations, notifyPayments
  // Frontpage sections: testimonials
  sections          Json     @default("{\"hero\":true,\"events\":true,\"gallery\":true,\"sponsors\":true,\"testimonials\":true,\"about\":true,\"contact\":true,\"moduleSpeakers\":true,\"moduleSponsors\":true,\"moduleCertificates\":true,\"moduleRegistrations\":true,\"notifyRegistrations\":true,\"notifyPayments\":true}")

  // Hero Section Config
  heroTitle         String?            // "Advance Your Medical Career"
  heroSubtitle      String?            // "Register for upcoming conferences..."
  heroBgImage       String?            // Background image for hero

  // About Section Config
  aboutTitle        String?
  aboutDescription  String?  @db.Text
  aboutFeatures     Json?              // Array of features [{icon, title, description}]
  aboutImages       Json?              // Array of image URLs for about slideshow

  // Gallery Config
  galleryImages     Json?              // Array of images [{src, alt, category}]
  galleryVideos     Json?              // Array of videos [{thumbnail, title, youtubeId, duration}]

  // Testimonials Config
  testimonials      Json?              // Array of [{name, role, avatar, content, rating}]

  // Yearly Stats Config
  yearlyStats       Json?              // {year, events, attendees, speakers}

  // FAQ Config
  faqs              Json?              // Array of [{id, question, answer}]

  // Ongoing Research Config
  researchItems     Json?              // Array of [{id, icon, title, description, status}]

  // Footer Config
  footerText        String?
  copyrightText     String?

  // Payment Settings (configured by Super Admin)
  paymentMode       PaymentMode @default(NONE)
  razorpayKeyId     String?            // Razorpay Key ID
  razorpayKeySecret String?            // Razorpay Key Secret (encrypted)
  paymentQrCode     String?            // QR code image URL for manual payments
  paymentUpiId      String?            // UPI ID displayed with QR code
  paymentInstructions String? @db.Text // Instructions shown during QR payment

  // Settings
  isActive          Boolean  @default(true)
  defaultCurrency   String   @default("INR")
  defaultTimezone   String   @default("Asia/Kolkata")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  events            Event[]
  users             User[]
  speakers          Speaker[]
  sponsors          Sponsor[]
  notificationChannels NotificationChannel[]
  notifications        Notification[]
  messageTemplates  MessageTemplate[]
  messageLogs       MessageLog[]

  @@index([slug])
  @@index([domain])
  @@map("tenants")
}

// ============================================================================
// NOTIFICATION CHANNEL MODEL
// ============================================================================

enum NotificationChannelType {
  EMAIL
  SMS
  WHATSAPP
}

model NotificationChannel {
  id          String                  @id @default(cuid())
  channel     NotificationChannelType
  provider    String                  // e.g., "gmail_smtp", "sendgrid", "twilio", "whatsapp_business"
  name        String                  // Display label, e.g., "Gmail — admin@priism.in"
  config      Json                    // Provider-specific config (encrypted sensitive fields)
  isActive    Boolean                 @default(true)
  isDefault   Boolean                 @default(false) // Default channel per type

  // Multi-tenancy (null = platform-level)
  tenantId    String?
  tenant      Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([tenantId, channel])
  @@map("notification_channels")
}

// ============================================================================
// IN-APP NOTIFICATION MODEL
// ============================================================================

enum NotificationType {
  NEW_REGISTRATION
  NEW_EVENT
  REGISTRATION_CONFIRMED
  PAYMENT_RECEIVED
  EVENT_PUBLISHED
  EVENT_CANCELLED
  GENERAL
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?          // Optional deep-link, e.g., "/dashboard/registrations/xyz"

  // Who receives it
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Multi-tenancy
  tenantId  String?
  tenant    Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
  @@index([tenantId])
  @@map("notifications")
}

// ============================================================================
// AUTH MODELS (NextAuth.js)
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?   // Hashed password for credentials auth
  name          String?
  firstName     String?
  lastName      String?
  phone         String?
  avatar        String?   // URL to avatar image
  role          UserRole  @default(ATTENDEE)
  isActive      Boolean   @default(true)

  // Multi-tenancy
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // Notification Preferences
  notifyEmail          Boolean @default(true)  // Receive updates via email
  notifyRegistrations  Boolean @default(true)  // New registration alerts
  notifyPayments       Boolean @default(true)  // Payment notifications

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  registrations Registration[] @relation("UserRegistrations")
  registeredBy  Registration[] @relation("RegisteredByUser")
  otps          OTP[]
  notifications Notification[]
  engagementResponses EngagementResponse[]

  @@index([tenantId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  // Device & Location Info
  deviceName   String?  // e.g., "Chrome on Windows"
  deviceType   String?  // desktop, mobile, tablet
  browser      String?  // Chrome, Firefox, Safari, etc.
  os           String?  // Windows, macOS, iOS, Android, etc.
  ipAddress    String?
  location     String?  // City, Country (from IP)

  // Activity tracking
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model OTP {
  id        String     @id @default(cuid())
  code      String
  purpose   OTPPurpose
  email     String
  userId    String?
  expiresAt DateTime
  used      Boolean    @default(false)

  createdAt DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose])
  @@map("otps")
}

// ============================================================================
// EVENT MODELS
// ============================================================================

model Event {
  id                   String      @id @default(cuid())
  title                String
  slug                 String      @unique
  shortDescription     String?     @db.Text
  description          String?     @db.Text

  // Date & Time (optional for drafts, required for publishing)
  startDate            DateTime?
  endDate              DateTime?
  startTime            String?     // e.g., "09:00"
  endTime              String?     // e.g., "17:00"
  timezone             String      @default("UTC")

  // Location
  location             String?
  address              String?
  city                 String?
  state                String?
  country              String?
  mapLink              String?
  isVirtual            Boolean     @default(false)
  virtualLink          String?

  // Capacity & Registration
  capacity             Int         @default(100)
  registrationOpensDate DateTime?  // When registration opens (defaults to now if not set)
  registrationDeadline DateTime?   // When registration closes
  isRegistrationOpen   Boolean     @default(true)

  // Pricing
  price                Decimal     @default(0) @db.Decimal(10, 2)
  earlyBirdPrice       Decimal?    @db.Decimal(10, 2)
  earlyBirdDeadline    DateTime?
  currency             String      @default("INR")

  // Status & Meta
  status               EventStatus @default(DRAFT)
  type                 EventType   @default(CONFERENCE)
  category             String?
  tags                 String[]

  // Additional Info
  cmeCredits           Int?
  cmeCoordinatorName   String?
  cmeCoordinatorEmail  String?
  cmeCoordinatorDesignation String?
  organizer            String?
  contactEmail         String?
  contactPhone         String?
  website              String?
  includes             String[]  // What's included in the event (e.g., "Conference kit", "Lunch")

  // Media
  bannerImage          String?
  thumbnailImage       String?

  // Certificate Signatories
  signatory1Name       String?
  signatory1Title      String?
  signatory2Name       String?
  signatory2Title      String?

  // Settings
  isPublished          Boolean     @default(false)
  isFeatured           Boolean     @default(false)

  // ID Card Settings
  idCardRequirePhoto   Boolean     @default(false)
  idCardSingleSided    Boolean     @default(true)
  badgeCategories      Json?       // [{id, label, color, bgColor, borderColor}]

  // Admin-customizable config (JSON arrays — null = use system defaults)
  participantRoles     Json?       // [{id, label, showOnPublicReg, certificate: {title, bodyText, colors}}]
  sessionTypes         Json?       // [{id, label, icon, colors: {bg, border, badge}}]
  certificateConfig    Json?       // {signatoryOverrides, globalColors, etc.}

  // Multi-tenancy
  tenantId             String?
  tenant               Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  // Relations
  registrations        Registration[]
  eventSpeakers        EventSpeaker[]
  eventSessions        EventSession[]
  eventSponsors        EventSponsor[]
  certificates         Certificate[]
  quizzes              Quiz[]
  pricingCategories    EventPricing[]
  engagements          EventEngagement[]
  halls                EventHall[]
  zones                EventZone[]
  scanLogs             ScanLog[]
  accessPoints         AccessPoint[]
  foodZones            FoodZone[]
  foodLogs             FoodLog[]
  messageLogs          MessageLog[]

  @@index([status])
  @@index([startDate])
  @@index([isPublished])
  @@index([tenantId])
  @@map("events")
}

// ============================================================================
// EVENT PRICING MODEL (Category-based pricing)
// ============================================================================

model EventPricing {
  id                String    @id @default(cuid())
  eventId           String

  // Category Info
  name              String              // e.g., "Faculty", "Student", "Professional"
  description       String?

  // Capacity
  totalSlots        Int       @default(20)

  // Pricing
  price             Decimal   @db.Decimal(10, 2)
  earlyBirdPrice    Decimal?  @db.Decimal(10, 2)
  earlyBirdDeadline DateTime?

  // Display order
  displayOrder      Int       @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  event             Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_pricing")
}

// ============================================================================
// REGISTRATION MODELS
// ============================================================================

model Registration {
  id               String             @id @default(cuid())

  // Attendee Info (denormalized for non-user registrations)
  userId           String?
  name             String
  email            String
  phone            String?
  organization     String?
  designation      String?
  category         String?            // Faculty, Resident, Student, etc.
  participantRole  String?            // DELEGATE, SPEAKER, ORGANIZER, VOLUNTEER, CHAIRPERSON

  // Registration Details
  eventId          String
  status           RegistrationStatus @default(PENDING)
  paymentStatus    PaymentStatus      @default(PENDING)
  amount           Decimal            @db.Decimal(10, 2)
  currency         String             @default("INR")

  // Payment Info
  paymentId        String?            // External payment reference
  paymentMethod    String?            // razorpay, qr_code, free, admin_manual
  razorpayOrderId  String?            // Razorpay order ID
  razorpayPaymentId String?           // Razorpay payment ID
  razorpaySignature String?           // Razorpay signature for verification
  paymentProof     String?            // QR code payment proof image URL
  paidAt           DateTime?

  // Attendance
  attendanceStatus String?            // checked_in, no_show, etc.
  checkedInAt      DateTime?
  qrCode           String?
  badgeGenerated   Boolean            @default(false)
  photo            String?            // Attendee photo URL for ID card

  // Notes
  notes            String?            @db.Text
  specialRequests  String?            @db.Text

  // Registration Source - tracks who created this registration
  // null = self-registration (public), set = registered by admin/staff
  registeredById   String?

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  user             User?              @relation("UserRegistrations", fields: [userId], references: [id], onDelete: SetNull)
  event            Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registeredBy     User?              @relation("RegisteredByUser", fields: [registeredById], references: [id], onDelete: SetNull)
  certificates     Certificate[]
  quizParticipants QuizParticipant[]
  scanLogs         ScanLog[]
  foodLogs         FoodLog[]

  @@unique([email, eventId])
  @@index([eventId])
  @@index([userId])
  @@index([registeredById])
  @@index([status])
  @@map("registrations")
}

// ============================================================================
// SPEAKER MODELS
// ============================================================================

model Speaker {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?

  // Professional Info
  designation  String?
  department   String?
  institution  String?
  biography    String?  @db.Text

  // Media
  photo        String?

  // Social Links
  linkedin     String?
  twitter      String?
  website      String?

  // Status
  isActive     Boolean  @default(true)

  // Multi-tenancy
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  eventSpeakers    EventSpeaker[]
  eventSessions    EventSession[]
  sessionSpeakers  SessionSpeaker[]

  @@index([tenantId])
  @@map("speakers")
}

model EventSpeaker {
  id              String   @id @default(cuid())
  eventId         String
  speakerId       String

  // Session Details
  topic              String?
  sessionDescription String?
  sessionDate        DateTime?
  sessionTime        String?
  sessionEndTime     String?
  sessionVenue       String?
  sessionOrder       Int      @default(0)

  // Status
  status          String   @default("pending") // pending, confirmed, cancelled
  isPublished     Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speaker      Speaker  @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@unique([eventId, speakerId])
  @@map("event_speakers")
}

// ============================================================================
// EVENT HALL MODEL (Venues/halls per event)
// ============================================================================

model EventHall {
  id           String   @id @default(cuid())
  eventId      String
  name         String   // e.g., "Hall A", "Auditorium 1"
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sessions     EventSession[]
  accessPoints AccessPoint[]

  @@unique([eventId, name])
  @@index([eventId])
  @@map("event_halls")
}

// ============================================================================
// EVENT SESSION MODEL (Independent sessions, optionally linked to speakers)
// ============================================================================

model EventSession {
  id              String   @id @default(cuid())
  eventId         String

  // Session Details
  title              String
  description        String?   @db.Text
  sessionType        String    @default("OTHER") // PLENARY, WORKSHOP, PANEL, KEYNOTE, BREAK, OTHER
  sessionDate        DateTime?
  startTime          String?
  endTime            String?
  venue              String?   // Legacy free-text venue
  hallId             String?   // Reference to EventHall
  sessionOrder       Int       @default(0)

  // Legacy Speaker Link (deprecated — use sessionSpeakers instead)
  speakerId          String?

  // Status
  status          String   @default("scheduled") // scheduled, ongoing, completed, cancelled
  isPublished     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  event            Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speaker          Speaker?         @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  hall             EventHall?       @relation(fields: [hallId], references: [id], onDelete: SetNull)
  sessionSpeakers  SessionSpeaker[]
  certificates     Certificate[]

  @@index([eventId])
  @@index([speakerId])
  @@index([hallId])
  @@map("event_sessions")
}

// ============================================================================
// SESSION SPEAKER MODEL (Multiple speakers per session with talk topics)
// ============================================================================

model SessionSpeaker {
  id              String   @id @default(cuid())
  sessionId       String
  speakerId       String

  // Talk Details
  talkTitle       String?
  talkDescription String?  @db.Text
  talkDuration    Int?     // duration in minutes
  displayOrder    Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  session      EventSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker      Speaker      @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@unique([sessionId, speakerId])
  @@index([sessionId])
  @@index([speakerId])
  @@map("session_speakers")
}

// ============================================================================
// EVENT ENGAGEMENT MODEL (Polls, Q&A, Feedback, etc.)
// ============================================================================

model EventEngagement {
  id           String   @id @default(cuid())
  eventId      String

  title        String
  type         String   // POLL, QA, FEEDBACK, ANNOUNCEMENT, QUIZ
  description  String?  @db.Text
  content      Json?    // Type-specific payload (poll options, quiz questions, etc.)
  isActive     Boolean  @default(false)
  displayOrder Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  responses    EngagementResponse[]

  @@index([eventId])
  @@map("event_engagements")
}

// ============================================================================
// ENGAGEMENT RESPONSE MODEL (Attendee responses to engagements)
// ============================================================================

model EngagementResponse {
  id            String   @id @default(cuid())
  engagementId  String
  userId        String?
  userName      String?
  response      Json     // { answer: "Option A" } for polls, { text: "..." } for Q&A/feedback, { word: "..." } for wordcloud

  createdAt     DateTime @default(now())

  engagement    EventEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([engagementId, createdAt])
  @@index([userId])
  @@map("engagement_responses")
}

// ============================================================================
// SPONSOR MODELS
// ============================================================================

model Sponsor {
  id          String      @id @default(cuid())
  name        String
  email       String?
  phone       String?

  // Company Info
  description String?     @db.Text
  website     String?

  // Media
  logo        String?

  // Status
  isActive    Boolean     @default(true)

  // Multi-tenancy
  tenantId    String?
  tenant      Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  eventSponsors EventSponsor[]

  @@index([tenantId])
  @@map("sponsors")
}

model EventSponsor {
  id          String      @id @default(cuid())
  eventId     String
  sponsorId   String
  tier        SponsorTier @default(SILVER)

  // Display
  displayOrder Int        @default(0)
  isPublished  Boolean    @default(true)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsor     Sponsor     @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@unique([eventId, sponsorId])
  @@map("event_sponsors")
}

// ============================================================================
// CERTIFICATE MODELS
// ============================================================================

model Certificate {
  id               String            @id @default(cuid())
  certificateCode  String            @unique // Unique verification code

  // Certificate Details
  registrationId   String            // Multiple certs per registration allowed
  eventId          String

  // Optional links for specific certificate types
  sessionId        String?           // For speaker session-specific certificates
  quizId           String?           // For quiz certificates

  // Certificate type classification
  certificateType  String            @default("ATTENDANCE")
  // Types: ATTENDANCE, SPEAKER_SESSION, ORGANIZATION, JUDGE,
  //        QUIZ_WINNER, QUIZ_FINALIST, QUIZ_PARTICIPATION,
  //        VOLUNTEER, CHAIRPERSON

  // Recipient Info (denormalized)
  recipientName    String
  recipientEmail   String

  // Certificate Content
  title            String?           // Certificate title/type
  description      String?           @db.Text
  cmeCredits       Int?
  position         Int?              // For quiz winners (1st=1, 2nd=2, 3rd=3)

  // Status
  status           CertificateStatus @default(PENDING)
  issuedAt         DateTime?
  revokedAt        DateTime?
  revokedReason    String?

  // Download tracking
  downloadCount    Int               @default(0)
  lastDownloadedAt DateTime?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  registration     Registration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  event            Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  session          EventSession?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  quiz             Quiz?             @relation(fields: [quizId], references: [id], onDelete: SetNull)

  @@unique([registrationId, sessionId, certificateType]) // Prevent duplicate certs for same session+type
  @@index([certificateCode])
  @@index([eventId])
  @@index([sessionId])
  @@index([quizId])
  @@map("certificates")
}

// ============================================================================
// QUIZ MODELS
// ============================================================================

model Quiz {
  id          String   @id @default(cuid())
  eventId     String
  title       String
  description String?  @db.Text
  status      String   @default("UPCOMING") // UPCOMING, ONGOING, COMPLETED

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  event        Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants QuizParticipant[]
  certificates Certificate[]

  @@index([eventId])
  @@map("quizzes")
}

model QuizParticipant {
  id             String   @id @default(cuid())
  quizId         String
  registrationId String
  score          Int?
  position       Int?     // 1, 2, 3 for podium
  isFinalist     Boolean  @default(false)
  isWinner       Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  quiz           Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([quizId, registrationId])
  @@index([quizId])
  @@index([registrationId])
  @@map("quiz_participants")
}

// ============================================================================
// EVENT ZONE & ACCESS CONTROL MODELS
// ============================================================================

model EventZone {
  id           String   @id @default(cuid())
  eventId      String
  name         String
  description  String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event        Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  accessRules  ZoneAccessRule[]
  scanLogs     ScanLog[]

  @@unique([eventId, name])
  @@index([eventId])
  @@map("event_zones")
}

model ZoneAccessRule {
  id       String  @id @default(cuid())
  zoneId   String
  category String
  allowed  Boolean @default(true)

  zone     EventZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, category])
  @@index([zoneId])
  @@map("zone_access_rules")
}

// ============================================================================
// SCAN LOG MODEL
// ============================================================================

model ScanLog {
  id             String     @id @default(cuid())
  eventId        String
  registrationId String
  scanType       ScanType
  zoneId         String?
  accessPointId  String?
  direction      String?    // IN, OUT
  result         ScanResult
  scannedAt      DateTime   @default(now())
  scannedBy      String?

  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  zone           EventZone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  accessPoint    AccessPoint? @relation(fields: [accessPointId], references: [id], onDelete: SetNull)

  @@index([eventId, scannedAt])
  @@index([registrationId])
  @@map("scan_logs")
}

// ============================================================================
// ACCESS POINT MODEL
// ============================================================================

model AccessPoint {
  id          String   @id @default(cuid())
  eventId     String
  name        String   // "Main Hall Entrance", "VIP Gate"
  type        String   @default("ACCESS") // ACCESS, FOOD
  hallId      String?  // Optional link to EventHall
  direction   String   @default("BOTH") // IN, OUT, BOTH
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  hall        EventHall? @relation(fields: [hallId], references: [id], onDelete: SetNull)
  scanLogs    ScanLog[]

  @@index([eventId])
  @@map("access_points")
}

// ============================================================================
// FOOD ZONE & FOOD LOG MODELS
// ============================================================================

model FoodZone {
  id          String   @id @default(cuid())
  eventId     String
  name        String   // "Lunch", "Tea Break", "Dinner"
  maxServings Int?     // Optional max count
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  foodLogs    FoodLog[]

  @@index([eventId])
  @@map("food_zones")
}

model FoodLog {
  id              String   @id @default(cuid())
  eventId         String
  foodZoneId      String
  registrationId  String
  servedAt        DateTime @default(now())
  scannedBy       String?

  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  foodZone       FoodZone     @relation(fields: [foodZoneId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([foodZoneId, registrationId])
  @@index([eventId, servedAt])
  @@map("food_logs")
}

// ============================================================================
// COMMUNICATION MODELS
// ============================================================================

model MessageTemplate {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String   // "Registration Confirmation", "Event Reminder", etc.
  subject     String
  body        String   @db.Text
  type        String   @default("EMAIL") // EMAIL, SMS
  isDefault   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("message_templates")
}

model MessageLog {
  id             String   @id @default(cuid())
  tenantId       String?
  eventId        String?
  recipientEmail String
  recipientName  String?
  subject        String
  channel        String   // EMAIL, SMS
  status         String   @default("SENT") // SENT, FAILED, PENDING
  errorMessage   String?

  createdAt      DateTime @default(now())

  tenant         Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  event          Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([eventId])
  @@map("message_logs")
}
